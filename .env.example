# DataSF Film Locations API
# Full URL including query-string parameters for pagination.
# The DataSF API is public and requires no authentication key.
VITE_DATASF_API_URL="https://data.sfgov.org/resource/yitu-d5am.json?$limit=3000&$offset=0"

# Map tile style (CARTO Voyager CDN — no key required)
VITE_MAP_STYLE_URL=https://basemaps.cartocdn.com/gl/voyager-gl-style/style.json
